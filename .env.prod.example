# Copy to ".env" on the server (next to docker-compose.prod.yml) and edit the values.

# Django secret — put a long random string (generate one, keep it secret)
SECRET_KEY=CHANGE_ME_to_a_long_random_string

# Your droplet's public IP or domain. Use * to accept any host (simplest to start).
ALLOWED_HOSTS=*

# Only turn this on AFTER you add a domain + HTTPS certificate. Leave False for plain http://IP.
SECURE_SSL_REDIRECT=False

# The site origin (for CSRF / CORS). Use your droplet IP or domain.
FRONTEND_ORIGIN=http://YOUR_SERVER_IP
CSRF_TRUSTED_ORIGINS=http://YOUR_SERVER_IP

# Database (used by the postgres container and the backend)
DB_NAME=accounting
DB_USER=accounting
DB_PASSWORD=CHANGE_ME_strong_db_password

# The admin account created automatically on first boot
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_strong_admin_password
DJANGO_SUPERUSER_EMAIL=you@example.com
