DEBUG=True
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL). For quick local trial you can set USE_SQLITE=True instead.
USE_SQLITE=False
DB_NAME=accounting
DB_USER=accounting
DB_PASSWORD=accounting
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS / frontend
FRONTEND_ORIGIN=http://localhost:5173

# JWT lifetimes (minutes / days)
ACCESS_TOKEN_LIFETIME_MIN=30
REFRESH_TOKEN_LIFETIME_DAYS=7
